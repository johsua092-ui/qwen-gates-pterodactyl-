# Port: di Pterodactyl biasanya otomatis dari SERVER_PORT, jadi boleh dikosongin
PORT=

# Kunci yang WAJIB dikirim client (Authorization: Bearer <kunci>). Kosongin = auth mati.
GATEWAY_KEY=ganti-dengan-kunci-rahasia

# Qwen (DashScope). Default endpoint internasional.
QWEN_API_KEY=sk-xxxx
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# GLM (Zhipu BigModel)
GLM_API_KEY=xxxx
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-xxxx
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# ---- Alias model -> id upstream ----
# Client manggil pakai nama alias (kolom kiri). Nilai di kanan = id model asli
# yang dikirim ke provider. Ganti nilainya kalau providermu pakai id yang beda
# (mis. ada tanggal/versi baru), tanpa perlu ubah kode.
MODEL_OPUS_48=claude-opus-4-1
MODEL_SONNET_5=claude-sonnet-4-5
MODEL_FABLE_5=claude-haiku-4-5
MODEL_QWEN_MAX_37=qwen-max
MODEL_QWEN_PLUS_37=qwen-plus
MODEL_GLM_52=glm-4-plus

# ---- CLI (opsional) ----
# Dipakai oleh cli.js / `gateway-chat` biar gak usah ngetik flag terus.
GATEWAY_URL=http://localhost:3000
GATEWAY_MODEL=qwen-plus-3.7
# GATEWAY_SYSTEM=Kamu asisten yang ramah dan jawab pakai Bahasa Indonesia.
